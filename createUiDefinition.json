{
  "$schema": "https://schema.management.azure.com/schemas/0.1.2-preview/CreateUIDefinition.MultiVm.json#",
  "handler": "Microsoft.Azure.CreateUIDef",
  "version": "0.1.2-preview",
  "parameters": {
    "config": {
      "isWizard": false,
      "basics": {
        "subscription": {
          "constraints": {
            "required": true
          }
        },
        "resourceGroup": {
          "allowExisting": true
        },
        "location": {
          "visible": false
        }
      }
    },
    "basics": [],
    "steps": [
      {
        "name": "clusterDetails",
        "label": "Target Cluster Details",
        "elements": [
          {
            "name": "existingClusterSection",
            "type": "Microsoft.Common.Section",
            "elements": [
              {
                "name": "clusterLookupControl",
                "type": "Microsoft.Solutions.ArmApiControl",
                "request": {
                  "method": "GET",
                  "path": "[concat(subscription().id, '/resourcegroups/', resourceGroup().name,  '/providers/Microsoft.ContainerService/managedClusters?api-version=2024-09-01')]"
                }
              },
              {
                "name": "existingClusterResourceName",
                "type": "Microsoft.Common.DropDown",
                "label": "AKS Cluster Name",
                "toolTip": "AKS Cluster Resource Name",
                "constraints": {
                  "allowedValues": "[map(steps('clusterDetails').existingClusterSection.clusterLookupControl.value, (item) => parse(concat('{\"label\":\"', item.name, '\",\"value\":\"', item.name, '\"}')))]",
                  "required": true
                }
              }
            ],
            "visible": true
          },
          {
            "name": "targetNamespace",
            "type": "Microsoft.Common.TextBox",
            "label": "Target Namespace",
            "defaultValue": "alluxio-test",
            "toolTip": "The namespace where the cluster will be deployed.",
            "constraints": {
              "required": true,
              "regex": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$",
              "validationMessage": "Namespace must be a valid Kubernetes DNS label."
            },
            "visible": true
          },
          {
            "name": "extensionResourceName",
            "type": "Microsoft.Common.TextBox",
            "label": "Cluster Extension Resource Name",
            "defaultValue": "alluxio-cluster-instance",
            "constraints": {
              "required": true,
              "regex": "^[a-z0-9][-a-z0-9]{4,28}[a-z0-9]$"
            }
          }
        ]
      },
      {
        "name": "alluxioConfig",
        "label": "Alluxio Configuration",
        "elements": [
          {
            "name": "Prerequisites check of your cluster",
            "type": "Microsoft.Common.TextBlock",
            "visible": true,
            "options": {
              "text": "Please confirm that the alluxio-operator extension is installed on your cluster.",
              "link": {
                "label": "To install the alluxio-operator extension, please click here.",
                "uri": "https://marketplace.microsoft.com/en-us/product/alluxio1770783070184.alluxio_operator?tab=Overview"
              }
            }
          },
          {
            "name": "alluxioClusterName",
            "type": "Microsoft.Common.TextBox",
            "label": "Alluxio Cluster Name",
            "defaultValue": "demo",
            "constraints": {
              "required": true
            }
          },
          {
            "name": "licenseString",
            "type": "Microsoft.Common.TextBox",
            "label": "Alluxio Enterprise License",
            "constraints": {
              "required": true
            }
          },
          {
            "name": "imageTag",
            "type": "Microsoft.Common.TextBox",
            "label": "Alluxio Enterprise Image Tag",
            "defaultValue": "AI-3.7-13.0.29",
            "constraints": {
              "required": true
            }
          },
          {
            "name": "deploymentProfile",
            "type": "Microsoft.Common.DropDown",
            "label": "Deployment with Advanced Configuration",
            "defaultValue": "standard",
            "constraints": {
              "allowedValues": [
                {
                  "label": "Standard (Default values)",
                  "value": "standard"
                },
                {
                  "label": "Custom (Advanced Configuration)",
                  "value": "custom"
                }
              ],
              "required": true
            }
          }
        ]
      },
      {
        "name": "advancedConfig",
        "label": "Advanced Resource Configuration",
        "elements": [
          {
            "name": "infoText",
            "type": "Microsoft.Common.TextBlock",
            "options": {
              "text": "These settings are applied because you selected 'Custom' profile."
            },
            "visible": "[equals(steps('alluxioConfig').deploymentProfile, 'custom')]"
          },
          {
            "name": "workerCount",
            "type": "Microsoft.Common.Slider",
            "label": "Worker Count",
            "min": 1,
            "max": 100,
            "defaultValue": 3,
            "visible": "[equals(steps('alluxioConfig').deploymentProfile, 'custom')]"
          },
          {
            "name": "etcdReplicaCount",
            "type": "Microsoft.Common.Slider",
            "label": "Etcd Replica Count",
            "min": 1,
            "max": 7,
            "defaultValue": 3,
            "visible": "[equals(steps('alluxioConfig').deploymentProfile, 'custom')]"
          },
          {
            "name": "etcdPersistenceEnabled",
            "type": "Microsoft.Common.CheckBox",
            "label": "If etcd Persistence enabled, you must select Storage Class below",
            "visible": "[equals(steps('alluxioConfig').deploymentProfile, 'custom')]"
          },
          {
            "name": "etcdStorageClass",
            "type": "Microsoft.Common.TextBox",
            "label": "Etcd Storage Class",
            "defaultValue": "managed-csi",
            "visible": "[and(equals(steps('alluxioConfig').deploymentProfile, 'custom'), steps('advancedConfig').etcdPersistenceEnabled)]"
          },
          {
            "name": "etcdStorageSize",
            "type": "Microsoft.Common.TextBox",
            "label": "Etcd Storage Size",
            "defaultValue": "50Gi",
            "visible": "[and(equals(steps('alluxioConfig').deploymentProfile, 'custom'), steps('advancedConfig').etcdPersistenceEnabled)]"
          },
          {
            "name": "workerPagestoreSize",
            "type": "Microsoft.Common.TextBox",
            "label": "Worker Pagestore Size",
            "defaultValue": "100Gi",
            "visible": "[equals(steps('alluxioConfig').deploymentProfile, 'custom')]"
          },
          {
            "name": "coordCpuLimit",
            "type": "Microsoft.Common.TextBox",
            "label": "Coordinator CPU Limit",
            "defaultValue": "8",
            "visible": "[equals(steps('alluxioConfig').deploymentProfile, 'custom')]"
          },
          {
            "name": "coordMemLimit",
            "type": "Microsoft.Common.TextBox",
            "label": "Coordinator Memory Limit",
            "defaultValue": "16Gi",
            "visible": "[equals(steps('alluxioConfig').deploymentProfile, 'custom')]"
          },
          {
            "name": "coordJvmXmx",
            "type": "Microsoft.Common.TextBox",
            "label": "Coordinator JVM Xmx",
            "defaultValue": "8g",
            "visible": "[equals(steps('alluxioConfig').deploymentProfile, 'custom')]"
          },
          {
            "name": "workerCpuLimit",
            "type": "Microsoft.Common.TextBox",
            "label": "Worker CPU Limit",
            "defaultValue": "10",
            "visible": "[equals(steps('alluxioConfig').deploymentProfile, 'custom')]"
          },
          {
            "name": "workerMemLimit",
            "type": "Microsoft.Common.TextBox",
            "label": "Worker Memory Limit",
            "defaultValue": "24Gi",
            "visible": "[equals(steps('alluxioConfig').deploymentProfile, 'custom')]"
          },
          {
            "name": "workerJvmXmx",
            "type": "Microsoft.Common.TextBox",
            "label": "Worker JVM Xmx",
            "defaultValue": "16g",
            "visible": "[equals(steps('alluxioConfig').deploymentProfile, 'custom')]"
          },
          {
            "name": "fuseCpuLimit",
            "type": "Microsoft.Common.TextBox",
            "label": "Fuse CPU Limit",
            "defaultValue": "6",
            "visible": "[equals(steps('alluxioConfig').deploymentProfile, 'custom')]"
          },
          {
            "name": "fuseMemLimit",
            "type": "Microsoft.Common.TextBox",
            "label": "Fuse Memory Limit",
            "defaultValue": "20Gi",
            "visible": "[equals(steps('alluxioConfig').deploymentProfile, 'custom')]"
          },
          {
            "name": "fuseJvmXmx",
            "type": "Microsoft.Common.TextBox",
            "label": "Fuse JVM Xmx",
            "defaultValue": "12g",
            "visible": "[equals(steps('alluxioConfig').deploymentProfile, 'custom')]"
          }
        ]
      }
    ],
    "outputs": {
      "location": "[location()]",
      "clusterResourceName": "[steps('clusterDetails').existingClusterSection.existingClusterResourceName]",
      "targetNamespace": "[steps('clusterDetails').targetNamespace]",
      "extensionResourceName": "[steps('clusterDetails').extensionResourceName]",
      "alluxioClusterName": "[steps('alluxioConfig').alluxioClusterName]",
      "licenseString": "[steps('alluxioConfig').licenseString]",
      "imageTag": "[steps('alluxioConfig').imageTag]",
      "deploymentProfile": "[steps('alluxioConfig').deploymentProfile]",
      "workerCount": "[steps('advancedConfig').workerCount]",
      "etcdReplicaCount": "[steps('advancedConfig').etcdReplicaCount]",
      "etcdPersistenceEnabled": "[steps('advancedConfig').etcdPersistenceEnabled]",
      "etcdStorageClass": "[coalesce(steps('advancedConfig').etcdStorageClass, 'managed-csi')]",
      "etcdStorageSize": "[coalesce(steps('advancedConfig').etcdStorageSize, '50Gi')]",
      "workerPagestoreSize": "[steps('advancedConfig').workerPagestoreSize]",
      "coordCpuLimit": "[steps('advancedConfig').coordCpuLimit]",
      "coordMemLimit": "[steps('advancedConfig').coordMemLimit]",
      "coordJvmXmx": "[steps('advancedConfig').coordJvmXmx]",
      "workerCpuLimit": "[steps('advancedConfig').workerCpuLimit]",
      "workerMemLimit": "[steps('advancedConfig').workerMemLimit]",
      "workerJvmXmx": "[steps('advancedConfig').workerJvmXmx]",
      "fuseCpuLimit": "[steps('advancedConfig').fuseCpuLimit]",
      "fuseMemLimit": "[steps('advancedConfig').fuseMemLimit]",
      "fuseJvmXmx": "[steps('advancedConfig').fuseJvmXmx]"
    }
  }
}